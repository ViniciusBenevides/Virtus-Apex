---
// src/pages/index.astro
import frameImagem from "../assets/frame_43.webp";
import baseImagem from "../assets/MOCKUP-BASE-matheus-santos.webp";
---

<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Carrossel com Frame</title>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
        />
    </head>
    <body>
        <section class="carousel-section">
            <div class="laptop-base">
                <img src={baseImagem.src} alt="Base do Notebook" />
            </div>

            <div class="laptop-frame-overlay">
                <img src={frameImagem.src} alt="Frame do Computador" />
            </div>

            <div class="swiper mySwiper">
                <div class="swiper-wrapper">
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 1"
                        />
                    </div>
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1504639725590-34d0984388bd?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 2"
                        />
                    </div>
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 3"
                        />
                    </div>
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 4"
                        />
                    </div>
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 1"
                        />
                    </div>
                    <div class="swiper-slide">
                        <img
                            src="https://images.unsplash.com/photo-1504639725590-34d0984388bd?auto=format&fit=crop&w=800&q=80"
                            alt="Tela 2"
                        />
                    </div>
                </div>
            </div>
        </section>

        <script
            is:inline
            src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"
        ></script>
        <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
                const swiper = new Swiper(".mySwiper", {
                    slidesPerView: "auto",
                    centeredSlides: true,
                    spaceBetween: 50,
                    loop: true,
                    speed: 1500,
                    autoplay: {
                        delay: 2000,
                        disableOnInteraction: false,
                    },
                });
            });
        </script>
    </body>
</html>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .carousel-section {
        position: relative;
        width: 100vw;
        max-width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 0;
        overflow: hidden;
        -webkit-mask-image: linear-gradient(
            to right,
            transparent,
            black 15%,
            black 85%,
            transparent
        );
        mask-image: linear-gradient(
            to right,
            transparent,
            black 15%,
            black 85%,
            transparent
        );
    }

    .laptop-base {
        margin-top: -15px;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 15;
        pointer-events: none;
        width: 700px;
    }

    .laptop-base img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
    }

    .laptop-frame-overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 10;
        pointer-events: none;
        width: 625px;
        height: 365px;
    }

    .laptop-frame-overlay img {
        width: 625px;
        height: 393px;
        display: block;
        object-fit: contain;
    }

    .swiper {
        width: 100%;
        overflow: visible;
        z-index: 5;
    }

    .swiper-slide {
        width: 530px;
        height: 360px;
        border-radius: 15px;
        overflow: hidden;
        /* Suaviza a transição de opacidade se desejar */
        transition: opacity 0.3s ease;
    }

    /* Opcional: deixa os slides das pontas levemente transparentes antes de sumirem */
    .swiper-slide:not(.swiper-slide-active) {
        opacity: 0.8;
    }

    .swiper-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top;
    }

    @media (max-width: 768px) {
        .laptop-frame-overlay {
            width: 340px;
            height: 213px;
        }
        .laptop-frame-overlay img {
            width: 340px;
            height: 213px;
        }
        .laptop-base {
            width: 380px;
            transform: translate(-50%, calc(-50% + 105px));
        }
        .swiper-slide {
            width: 258px !important;
            height: 162px;
        }
        /* Ajuste do gradiente para telas menores para não "comer" muito a tela */
        .carousel-section {
            -webkit-mask-image: linear-gradient(
                to right,
                transparent,
                black 5%,
                black 95%,
                transparent
            );
            mask-image: linear-gradient(
                to right,
                transparent,
                black 5%,
                black 95%,
                transparent
            );
        }
    }
</style>
