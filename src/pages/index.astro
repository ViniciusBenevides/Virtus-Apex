---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import background from "../assets/bg1-desktop-webp.png";

// Secções refatoradas da Página
import HeroSection from "../components/sections/HeroSection.astro";
import InfiniteTicker from "../components/sections/InfiniteTicker.astro";
import BenefitsSection from "../components/sections/BenefitsSection.astro";
import LaptopCarousel from "../components/sections/LaptopCarousel.astro";
import CaptureSection from "../components/sections/CaptureSection.astro";
import NeedsSection from "../components/sections/NeedsSection.astro";
import CreationProcess from "../components/sections/CreationProcess.astro";
import PricingSection from "../components/sections/PricingSection.astro";
import FaqSection from "../components/sections/FaqSection.astro";
import FooterSection from "../components/sections/FooterSection.astro";
---

<Layout title="Vinícius Benevides | Landing Pages Exclusivas">
	<style is:global>
		@font-face {
			font-family: "Paralucent";
			src: url("/src/fonts/fonnts.com-Paralucent_Medium.otf")
				format("opentype");
			font-weight: medium;
			font-style: normal;
			font-display: swap;
		}

		@font-face {
			font-family: "Paralucent";
			src: url("/src/fonts/fonnts.com-Paralucent_Light.otf")
				format("opentype");
			font-weight: light;
			font-style: normal;
			font-display: swap;
		}

		:root {
			--c1: rgba(154, 235, 247, 1);
			--c2: rgba(154, 235, 247, 0.1);
			/* Cor do Container dos Cards (Mais clara que o fundo preto) */
			--card-section-bg: #15171ebf;
		}

		/* --- Animações do Spinner (Usado em várias seções) --- */
		@keyframes borderRotate {
			100% {
				--angle: 420deg;
			}
		}

		@keyframes flash-interval {
			0%,
			100% {
				opacity: 0;
			}
			5% {
				opacity: 0.95;
			}
			10% {
				opacity: 0;
			}
		}

		.conic-spinner {
			background: conic-gradient(
				from var(--angle),
				var(--c2),
				var(--c1) 0.1turn,
				var(--c1) 0.15turn,
				var(--c2) 0.25turn
			);
			animation: borderRotate 2500ms linear infinite forwards;
		}

		.flash-overlay {
			animation: flash-interval 3.8s ease-in-out infinite;
		}

		/* --- Infinite Scroll --- */
		@keyframes infinite-scroll {
			from {
				transform: translateX(0);
			}
			to {
				transform: translateX(-50%);
			}
		}

		.animate-infinite-scroll {
			animation: infinite-scroll 40s linear infinite;
		}

		.mask-gradient {
			mask-image: linear-gradient(
				to right,
				transparent,
				black 10%,
				black 90%,
				transparent
			);
			-webkit-mask-image: linear-gradient(
				to right,
				transparent,
				black 10%,
				black 90%,
				transparent
			);
		}
	</style>

	{/* Section 1: Top Hero Cover */}
	<main
		class="min-h-screen w-full bg-cover bg-center bg-no-repeat flex flex-col items-center text-center relative overflow-hidden pb-0 bg-[#06060E]"
		style={`background-image: url(${background.src});`}
	>
		<div class="absolute inset-0"></div>

		<HeroSection />
	</main>

	{/* Section 2: Detalhes, Carousel e Beneficios */}
	<div class="w-full bg-[#06060E] relative pb-0 overflow-x-hidden">
		<InfiniteTicker />

		<BenefitsSection />

		<LaptopCarousel />

		<CaptureSection />

		<NeedsSection />

		<CreationProcess />

		<PricingSection />

		<FaqSection />
	</div>

	{/* Section 3: Footer */}
	<FooterSection />
</Layout>
