---
// 1. IMPORTANDO O CSS DO TAILWIND
// Isso avisa pro site carregar os estilos globais
import '../styles/global.css';

// 2. DEFININDO AS PROPRIEDADES
// Isso permite que você mude o título da aba do navegador em cada página
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-br">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portfólio Vinícius Benevides" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>