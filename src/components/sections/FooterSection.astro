---
import { Image } from "astro:assets";
import VirtusApex from "../../assets/astro-framework1720735660.logowik.com-Recuperado2.png";
import LogoApex from "../../assets/logo-apex.png";
import WorldMap from "../WorldMap.astro";
---

<footer class="site-footer relative z-20">
    <div class="footer-main">
        {/* Left content */}
        <div class="footer-left animate-on-scroll delay-100">
            <p class="footer-tagline">
                Inicie a jornada para ter um <strong
                    >site incrível hoje mesmo.</strong
                >
            </p>
            <h2 class="footer-rotating-text" id="footer-rotating-text">
                Transforme visitantes em clientes.
            </h2>
            <p class="footer-description">
                No mundo do web design, cada linha de código é uma oportunidade
                de criar algo incrível. Cada projeto é uma tela em branco
                esperando para ganhar vida. Lembre-se de que, por trás de cada
                clique, há uma pessoa em busca de algo especial. Portanto, vamos
                fazer dessa experiência algo especial.
            </p>
        </div>

        {/* Right content */}
        <div class="footer-right animate-on-scroll delay-200">
            <div class="footer-designed-by">
                <span class="footer-designed-label">designed by</span>
                <Image
                    src={VirtusApex}
                    alt="Virtus Apex"
                    width={200}
                    height={200}
                    class="footer-designer-logo"
                />
            </div>
            <p class="footer-designer-info">
                Virtus Apex - Web Designer © 2025
            </p>
            <div class="footer-designer-avatar">
                <span class="footer-designer-name">Virtus<br />Apex</span>
                <div class="footer-avatar-circle">
                    <Image
                        src={LogoApex}
                        alt="Logo Apex"
                        width={80}
                        height={80}
                        class="footer-avatar-img"
                    />
                </div>
            </div>
        </div>

        {/* World map dots */}
        <div class="footer-worldmap">
            <WorldMap />
        </div>
    </div>

    {/* Bottom bar */}
    <div class="footer-bottom animate-on-scroll delay-300">
        <div class="footer-bottom-left">
            <p class="footer-cnpj">CNPJ: 63.685.153/0001-30</p>
            <p class="footer-rights">
                <strong>Todos os Direitos Reservados</strong>
            </p>
        </div>
        <div class="footer-bottom-right">
            <a
                href="https://www.instagram.com/virtusapex/"
                target="_blank"
                rel="noopener noreferrer"
                class="footer-ig-btn"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"
                    ></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                    ></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
                <span>@VirtusApex</span>
            </a>
            <a
                href="https://wa.me/5562981752097?text=Ol%C3%A1%2C+gostaria+de+solicitar+um+or%C3%A7amento."
                target="_blank"
                rel="noopener noreferrer"
                class="footer-zap-btn"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                >
                    <path
                        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
                    ></path>
                    <path
                        d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 0 0 .612.612l4.458-1.495A11.952 11.952 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.352 0-4.55-.764-6.334-2.064l-.44-.329-3.27 1.096 1.096-3.27-.329-.44A9.965 9.965 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
                    ></path>
                </svg>
            </a>
            <button
                class="footer-top-btn"
                id="footer-top-btn"
                aria-label="Voltar ao topo"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M12 19V5M5 12l7-7 7 7"></path>
                </svg>
            </button>
        </div>
    </div>
</footer>

<style>
    /* --- FOOTER --- */
    .site-footer {
        background: #0a0b0f;
        border-top: 1px solid #1a1c22;
        padding: 0;
        position: relative;
        overflow: hidden;
    }

    .footer-main {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 80px 48px 100px;
        position: relative;
    }

    .footer-worldmap {
        position: absolute;
        top: 50%;
        left: 55%;
        transform: translate(-30%, -50%);
        width: 600px;
        height: 320px;
        opacity: 0.15;
        pointer-events: none;
        z-index: 0;
    }

    .footer-left {
        position: relative;
        z-index: 1;
    }

    .footer-tagline {
        font-family: "Paralucent", sans-serif;
        font-size: 14px;
        font-weight: 300;
        color: #abaeb4;
        margin: 0 0 32px 0;
    }

    .footer-tagline strong {
        color: #e8ebf0;
        font-weight: 600;
    }

    .footer-rotating-text {
        font-family: "Paralucent", sans-serif;
        font-size: 40px;
        font-weight: 800;
        color: #e8ebf0;
        line-height: 1.15;
        margin: 0 0 32px 0;
        min-height: 100px;
    }

    .footer-description {
        font-family: "Paralucent", sans-serif;
        font-size: 13px;
        font-weight: 300;
        color: #6b6f76;
        line-height: 1.7;
        max-width: 420px;
        margin: 0;
    }

    .footer-right {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

    .footer-designed-by {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .footer-designed-label {
        font-family: "Paralucent", sans-serif;
        font-size: 14px;
        font-weight: 300;
        font-style: italic;
        color: #6b6f76;
    }

    .footer-designer-logo {
        width: 120px;
        height: auto;
        object-fit: contain;
        opacity: 0.8;
    }

    .footer-designer-info {
        font-family: "Paralucent", sans-serif;
        font-size: 12px;
        font-weight: 300;
        color: #6b6f76;
        margin: 0;
        text-align: right;
    }

    .footer-designer-avatar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 8px;
    }

    .footer-designer-name {
        font-family: "Paralucent", sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: #abaeb4;
        text-align: right;
        line-height: 1.3;
    }

    .footer-avatar-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #1a1c22;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 1px solid #2a2d35;
    }

    .footer-avatar-img {
        width: 36px;
        height: 36px;
        object-fit: contain;
        border-radius: 50%;
    }

    /* --- Bottom bar --- */
    .footer-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px 48px;
        border-top: 1px solid #1a1c22;
    }

    .footer-bottom-left {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .footer-cnpj {
        font-family: "Paralucent", sans-serif;
        font-size: 11px;
        font-weight: 300;
        color: #5c666f;
        margin: 0;
        letter-spacing: 0.5px;
    }

    .footer-rights {
        font-family: "Paralucent", sans-serif;
        font-size: 12px;
        font-weight: 400;
        color: #abaeb4;
        margin: 0;
    }

    .footer-bottom-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .footer-ig-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 28px;
        background: #1a1c22;
        border: 1px solid #2a2d35;
        border-radius: 999px;
        color: #e8ebf0;
        font-family: "Paralucent", sans-serif;
        font-size: 13px;
        font-weight: 400;
        text-decoration: none;
        transition: all 0.3s ease;
        letter-spacing: 0.3px;
    }

    .footer-ig-btn:hover {
        background: #22242c;
        border-color: #3a3d45;
    }

    .footer-zap-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: #1a1c22;
        border: 1px solid #2a2d35;
        border-radius: 50%;
        color: #e8ebf0;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .footer-zap-btn:hover {
        background: #22242c;
        border-color: #3a3d45;
    }

    .footer-top-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px;
        height: 48px;
        background: #e8ebf0;
        border: none;
        border-radius: 50%;
        color: #0a0b0f;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .footer-top-btn:hover {
        background: #ffffff;
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .footer-main {
            grid-template-columns: 1fr;
            gap: 40px;
            padding: 60px 24px 60px;
        }

        .footer-right {
            align-items: flex-start;
        }

        .footer-rotating-text {
            font-size: 28px;
            min-height: 70px;
        }

        .footer-bottom {
            flex-direction: column;
            gap: 20px;
            padding: 24px;
            align-items: flex-start;
        }

        .footer-bottom-right {
            width: 100%;
            justify-content: flex-start;
        }

        .footer-worldmap {
            left: 50%;
            transform: translate(-50%, -50%);
            width: 400px;
            opacity: 0.15;
        }
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        // --- Footer rotating text ---
        const footerRotatingEl = document.getElementById(
            "footer-rotating-text",
        );
        if (footerRotatingEl) {
            const footerPhrases = [
                "Transforme visitantes em clientes.",
                "Demonstre o valor da sua oferta.",
                "Impressione seus leads.",
            ];
            let footerPhraseIndex = 0;

            function footerUpdateText() {
                footerPhraseIndex =
                    (footerPhraseIndex + 1) % footerPhrases.length;
                footerRotatingEl.style.opacity = "0";
                footerRotatingEl.style.transform = "translateY(10px)";
                setTimeout(() => {
                    footerRotatingEl.textContent =
                        footerPhrases[footerPhraseIndex];
                    footerRotatingEl.style.opacity = "1";
                    footerRotatingEl.style.transform = "translateY(0)";
                }, 400);
            }

            footerRotatingEl.style.transition =
                "opacity 0.4s ease, transform 0.4s ease";
            setInterval(footerUpdateText, 3000);
        }

        // --- Scroll to top ---
        const topBtn = document.getElementById("footer-top-btn");
        if (topBtn) {
            topBtn.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });
        }
    });
</script>
